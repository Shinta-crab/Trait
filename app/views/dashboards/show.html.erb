<div class="min-h-screen bg-[#f9f7f2] p-8">
  <div class="max-w-6xl mx-auto">
    <header class="flex justify-between items-center px-10 h-[60px] flex-shrink-0">
      <h1 class="font-[300] tracking-[4px] uppercase text-sm">
        <%= link_to "Trait", root_path, class: "text-[#4a4a4a] no-underline" %>
      </h1>
    </header>

    <header class="flex justify-between items-center mb-1">
      <div>
        <h1 class="text-2xl font-[300] text-[#4a4a4a] tracking-widest uppercase">My Dashboard</h1>
        <p class="text-sm text-gray-500 mt-1">こんにちは、<%= current_user.account_name %> さん</p>
      </div>
      <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs text-gray-400 hover:text-black" %>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-[60px]">
      <%# 保存済みスタイル一覧 %>
      <% @my_styles.each do |style| %>
        <div class="bg-white rounded-sm shadow-sm overflow-hidden border border-black/5 flex flex-col group">
          <% first_photo = style.selected_photos.first %>
          <% if first_photo %>
            <div class="aspect-[4/3] bg-cover bg-center" style="background-image: url('<%= first_photo.display_image_url %>')">
              <div class="m-2 inline-block px-2 py-1 bg-black/50 text-white text-[9px] uppercase tracking-widest"><%= style.genre.name %></div>
            </div>
          <% else %>
            <div class="aspect-[4/3] bg-stone-200 flex items-center justify-center text-stone-400">No Image</div>
          <% end %>

          <div class="p-4 flex-grow flex flex-col justify-between">
            <div>
              <h3 class="text-lg font-[300] text-[#4a4a4a]"><%= style.custom_name %></h3>
              <p class="text-[10px] text-gray-400 mt-1"><%= style.created_at.strftime("%Y.%m.%d") %></p>
            </div>
            
            <div class="mt-6 flex justify-between items-center pt-4 border-t border-gray-50">
              <%= link_to "View Detail", my_style_path(style), class: "text-[11px] text-[#4a4a4a] underline uppercase tracking-tighter" %>
              
              <%# 削除ボタン: data-turbo-method と confirm を使用 %>
              <%= link_to "Delete", my_style_path(style), 
                  data: { turbo_method: :delete, turbo_confirm: "このスタイルを削除してもよろしいですか？" }, 
                  class: "text-[10px] text-red-300 hover:text-red-500 transition uppercase tracking-widest" %>
            </div>
          </div>
        </div>
      <% end %>

      <%# 空きスロット（追加ボタン） %>
      <% @empty_slots_count.times do %>
        <%= link_to genres_path, class: "group bg-white/40 border-2 border-dashed border-stone-200 rounded-sm aspect-[4/3] flex flex-col items-center justify-center hover:border-stone-400 hover:bg-white transition" do %>
          <span class="text-3xl text-stone-300 group-hover:text-stone-500 mb-1 font-[100]">+</span>
          <p class="text-[9px] text-stone-400 group-hover:text-stone-600 uppercase tracking-[0.2em]">New Analysis</p>
        <% end %>
      <% end %>
    </div>

    <footer class="flex-shrink-0 py-4 text-center border-t border-black/5 text-[12px] bg-[#f9f7f2]">
      <div class="mb-2">
        <%= link_to "Home", root_path, class: "mx-4 text-[#333] no-underline hover:text-[#d4a373]" %>
        <%= link_to "利用規約", terms_path, class: "mx-4 text-[#333] no-underline hover:text-[#d4a373]" %>
        <a href="#" class="mx-4 text-[#333] no-underline">お問い合わせ</a>
      </div>
      <p class="text-[10px] text-gray-400">&copy; 2026 Trait</p>
    </footer>
  </div>
</div>
