<div class="min-h-screen bg-[#f9f7f2] flex flex-col">
  <%# ヘッダー %>
  <header class="flex justify-between items-center px-10 h-[60px] flex-shrink-0">
    <h1 class="font-[300] tracking-[4px] uppercase text-sm">
      <%= link_to "Trait", root_path, class: "text-[#4a4a4a] no-underline" %>
    </h1>
  </header>

  <%# 認証コンテナ %>
  <main class="flex-grow flex items-center justify-center px-4 py-12">
    <div class="bg-white p-10 rounded-[4px] shadow-[0_4px_20px_rgba(0,0,0,0.05)] w-full max-w-[400px]">
      
      <h2 class="text-2xl font-[300] text-[#4a4a4a] mb-8 text-center tracking-wider">Login</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        
        <%# アカウント名でのログイン %>
        <div class="mb-6">
          <%= f.label :account_name, "Account Name", class: "block text-[12px] mb-1.5 text-[#4a4a4a] tracking-wider uppercase" %>
          <%= f.text_field :account_name, autofocus: true, placeholder: "アカウント名を入力してください", 
              class: "w-full p-3 border border-[#ddd] rounded-[4px] text-sm focus:outline-none focus:border-[#4a4a4a] transition-colors" %>
        </div>

        <%# パスワード %>
        <div class="mb-2">
          <div class="flex justify-between items-center">
            <%= f.label :password, "Password", class: "block text-[12px] text-[#4a4a4a] tracking-wider uppercase" %>
            <%# パスワードをお忘れの方はこちら %>
            <%= link_to "Forgot?", new_password_path(resource_name), class: "text-[10px] text-gray-400 hover:text-[#d4a373] transition-colors" %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password", 
              class: "w-full p-3 mt-1 border border-[#ddd] rounded-[4px] text-sm focus:outline-none focus:border-[#4a4a4a] transition-colors" %>
        </div>

        <%# ログイン状態を保持する（任意） %>
        <% if devise_mapping.rememberable? %>
          <div class="mb-8 flex items-center">
            <%= f.check_box :remember_me, class: "w-3 h-3 border-gray-300 rounded focus:ring-0 accent-[#4a4a4a]" %>
            <%= f.label :remember_me, "ログイン状態を保持する", class: "ml-2 text-[11px] text-gray-500" %>
          </div>
        <% end %>

        <%# 送信ボタン %>
        <div class="actions">
          <%= f.submit "ログイン", class: "w-full py-4 bg-[#4a4a4a] text-white text-[15px] tracking-[2px] cursor-pointer hover:opacity-90 transition-all rounded-[2px] font-bold" %>
        </div>
      <% end %>

      <%# フッターリンク：新規登録画面への遷移 %>
      <div class="mt-8 pt-6 border-t border-gray-100 text-center text-xs text-gray-500">
        <p>アカウントをお持ちではないですか？ <%= link_to "新規登録", new_registration_path(resource_name), class: "text-[#d4a373] hover:underline font-bold" %></p>
      </div>
    </div>
  </main>

  <%# フッター（他画面と共通） %>
  <footer class="flex-shrink-0 py-4 text-center border-t border-black/5 text-[12px] bg-[#f9f7f2]">
    <div class="mb-2">
      <%= link_to "Home", root_path, class: "mx-4 text-[#333] no-underline hover:text-[#d4a373]" %>
      <%= link_to "利用規約", terms_path, class: "mx-4 text-[#333] no-underline hover:text-[#d4a373]" %>
      <%# <a href="#" class="mx-4 text-[#333] no-underline">お問い合わせ</a> %>
    </div>
    <p class="text-[10px] text-gray-400">&copy; 2026 Trait</p>
  </footer>
</div>
